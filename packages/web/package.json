{
  "name": "@qqmusic-api/web",
  "version": "0.6.7",
  "type": "module",
  "description": "QQ Music API Web RESTful layer",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
