{
  "name": "@qqmusic-api/sdk",
  "version": "0.6.7",
  "type": "module",
  "description": "QQ Music API SDK for Node.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "cos-nodejs-sdk-v5": "^2.15.0",
    "jsonpath-plus": "^10.3.0",
    "mqtt": "^5.14.0",
    "undici": "^7.11.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
